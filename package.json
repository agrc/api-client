{
  "name": "ugrc-api-client",
  "version": "1.7.14",
  "description": "The official UGRC API client",
  "keywords": [
    "utah",
    "geocoding",
    "ugrc",
    "agrc",
    "electron"
  ],
  "homepage": "https://gis.utah.gov/products/sgid/address/api-client/",
  "bugs": "https://github.com/agrc/api-client/issues",
  "repository": "https://github.com/agrc/api-client",
  "license": "MIT",
  "contributors": [
    {
      "name": "Steve Gourley",
      "email": "sgourley@utah.gov"
    },
    {
      "name": "Scott Davis",
      "email": "stdavis@utah.gov"
    }
  ],
  "type": "module",
  "main": ".vite/build/main.js",
  "scripts": {
    "prebuild": "pnpm exec generate-license-file --config glf.json",
    "build": "pnpm prebuild && tsc -b && vite build",
    "check": "tsc -b --noEmit",
    "format": "prettier . --write",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "make": "electron-forge make",
    "package": "electron-forge package",
    "start": "cross-env ELECTRON_ENABLE_LOGGING=1 electron-forge start"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-unhandled": "^5.0.0",
    "electron-util": "^1.0.0",
    "electron-window-state": "^5.0.3",
    "humanize-duration": "^3.33.2",
    "ky": "^2.0.2",
    "lucide-react": "^1.17.0",
    "md5": "^2.3.0",
    "os-name": "^7.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-dropzone": "~15.0.0",
    "react-error-boundary": "^6.1.2",
    "react-navigator-status": "^0.1.2",
    "react-router": "^7.17.0",
    "update-electron-app": "^3.2.0",
    "use-immer": "^0.11.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "~2.1.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@ugrc/eslint-config": "^1.3.0",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "electron": "^42.3.3",
    "electron-squirrel-startup": "^1.0.1",
    "eslint": "^10.3.0",
    "generate-license-file": "^4.2.1",
    "lodash": "^4.18.1",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.16"
  },
  "productName": "ugrc-api-client"
}
